rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'; 
    }
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      
      allow create: if isSignedIn() && isValidId(userId) && request.auth.uid == userId;

      allow update: if isSignedIn() && isValidId(userId) && (
        isAdmin() ||
        (
          request.auth.uid == userId && 
          incoming().diff(existing()).affectedKeys().hasOnly(['name', 'phone', 'avatar', 'driverInfo', 'documents', 'driverApproved', 'status', 'role', 'rejectionReason', 'updatedAt']) &&
          (!('role' in incoming().diff(existing()).affectedKeys()) || incoming().role == existing().role)
        )
      );
    }

    match /drivers/{driverId} {
      allow get: if isSignedIn() && isValidId(driverId);
      allow list: if isSignedIn(); 
      allow create: if isSignedIn();

      allow update: if isSignedIn();
    }

    match /trips/{tripId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
    }

    match /settings/{settingId} {
      allow get: if isSignedIn() && isValidId(settingId);
      allow list: if isSignedIn();
      allow write: if isAdmin();
    }

    match /complaints/{complaintId} {
      allow read: if isSignedIn() && isValidId(complaintId) && (existing().userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidId(complaintId) && incoming().userId == request.auth.uid;
      allow update: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow get: if isSignedIn() && isValidId(notificationId) && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && existing().userId == request.auth.uid;
      allow create: if isAdmin() || (isSignedIn() && incoming().userId == request.auth.uid);
      allow update: if isSignedIn() && isValidId(notificationId) && request.auth.uid == existing().userId && incoming().diff(existing()).affectedKeys().hasOnly(['isRead']);
    }
  }
}
